# Copy to .env and fill in. NEVER commit .env (it holds secrets).
# .env is read automatically by docker compose.

# --- model swap (Phase 4+): the only knobs that change between models ---
MODEL_ID=Qwen/Qwen2.5-7B-Instruct          # HF repo the inference service serves
MODEL_NAME=qwen2.5-7b-instruct             # served name the coach calls
INFERENCE_BASE_URL=http://inference:8000/v1
# For a fast local iteration model, swap MODEL_ID to a 1.5-3B instruct model.
# For your fine-tuned model, point MODEL_ID at the merged repo — nothing else changes.

# --- secrets (never commit) ---
HF_TOKEN=                                  # only if pulling a gated base model
WANDB_API_KEY=                             # Phase 3+ tracking; or use `wandb login`

# --- caches ---
HF_HOME=./.hf_cache                        # model cache (gitignore this)
