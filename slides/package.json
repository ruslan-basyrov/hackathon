{
  "name": "conversion-coach-slides",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "slidev --open",
    "build": "slidev build",
    "export": "slidev export slides.md --output slides-export.pdf --timeout 60000",
    "export:brave": "slidev export slides.md --output slides-export.pdf --timeout 60000 --executable-path /usr/bin/brave"
  },
  "devDependencies": {
    "@slidev/cli": "^52.15.2",
    "@slidev/theme-default": "^0.25.0",
    "playwright-chromium": "^1.60.0"
  }
}
